# Amman Bakes POS — environment variables
# Copy to .env locally. Render injects DATABASE_URL automatically in production.

# ---- App ----
NODE_ENV=production
PORT=5000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d

# ---- MySQL ----
# Local development uses MySQL.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=billing_db
DB_USER=root
DB_PASSWORD=

# Production uses the managed PostgreSQL connection supplied by Render.
# DATABASE_URL=postgresql://user:password@host:5432/database

# ---- One-time schema sync ----
# Set this to `alter` on the FIRST deploy so Sequelize creates all tables.
# Remove after that deploy succeeds — leaving it on is fine but wastes time
# on every restart.
DB_SYNC=alter
