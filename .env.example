# Amman Bakes POS — environment variables
# Copy to .env locally, or paste into Railway's Variables tab in production.

# ---- App ----
NODE_ENV=production
PORT=5000                 # Railway auto-sets this; ignored on Railway.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d

# ---- MySQL ----
# On Railway, add the MySQL plugin and use MYSQLHOST / MYSQLPORT / MYSQLUSER /
# MYSQLPASSWORD / MYSQLDATABASE — reference them here via ${{ MySQL.VAR_NAME }}
# in Railway's variable UI.
DB_HOST=${{ MySQL.MYSQLHOST }}
DB_PORT=${{ MySQL.MYSQLPORT }}
DB_NAME=${{ MySQL.MYSQLDATABASE }}
DB_USER=${{ MySQL.MYSQLUSER }}
DB_PASSWORD=${{ MySQL.MYSQLPASSWORD }}

# ---- One-time schema sync ----
# Set this to `alter` on the FIRST deploy so Sequelize creates all tables.
# Remove after that deploy succeeds — leaving it on is fine but wastes time
# on every restart.
DB_SYNC=alter
